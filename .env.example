# Copy this file to .env.local and fill in your keys. .env.local is gitignored.

# Google Gemini — image generation (scripts/generate-images.mjs)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: switch the image model. Default is gemini-2.5-flash-image (Nano Banana).
# For higher-end photoreal stills with true aspect-ratio control:
#   IMAGE_MODEL=imagen-4.0-generate-001
# IMAGE_MODEL=

# Brevo (transactional email for the contact form) — wired later.
# BREVO_API_KEY=
